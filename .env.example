DISCORD_BOT_TOKEN=
# 1. 打开 Discord User Settings -> Advanced
# 2. 开启 Developer Mode
# 3. 回到你要装 bot 的那个服务器
# 4. 右键服务器图标
# 5. 点 Copy Server ID
DISCORD_GUILD_ID=
ALLOWED_BOT_IDS=
CODEX_CWD=./workspace
CODEX_BIN=codex

