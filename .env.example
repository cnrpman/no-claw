CODEX_DISCORD_BOT_TOKEN=
CLAUDE_DISCORD_BOT_TOKEN=
CODEX_FEISHU_APP_ID=
CODEX_FEISHU_APP_SECRET=
CLAUDE_FEISHU_APP_ID=
CLAUDE_FEISHU_APP_SECRET=
# Legacy fallback for the Codex bot only:
# DISCORD_BOT_TOKEN=
# 1. 打开 Discord User Settings -> Advanced
# 2. 开启 Developer Mode
# 3. 回到你要装 bot 的那个服务器
# 4. 右键服务器图标
# 5. 点 Copy Server ID
DISCORD_GUILD_ID=
ALLOWED_BOT_IDS=

CODEX_CWD=./workspace
CODEX_BIN=codex

CLAUDE_CWD=./workspace
CLAUDE_BIN=claude

# Optional explicit proxy override.
# If unset, the bot will try to read macOS system proxy settings from `scutil --proxy`.
# HTTP_PROXY=
# HTTPS_PROXY=
# ALL_PROXY=
# NO_PROXY=
